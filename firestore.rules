rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper: caller must have a user profile (i.e. be a registered app user) ──
    function isAppUser() {
      return request.auth != null &&
             exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    // ── User profiles ─────────────────────────────────────────────────────────
    // Users can read/write their own profile.
    // create is allowed with just auth (profile doesn't exist yet on first login).
    match /users/{uid} {
      allow get:    if request.auth != null && request.auth.uid == uid;
      allow create: if request.auth != null && request.auth.uid == uid;
      allow update: if request.auth != null && request.auth.uid == uid;
      allow delete: if false;
    }

    // ── Admins collection ─────────────────────────────────────────────────────
    // Readable by app users (so they can check their own admin status).
    // Only writable via Firebase Console / admin SDK.
    match /admins/{uid} {
      allow read:  if isAppUser();
      allow write: if false;
    }

    // ── Sessions ──────────────────────────────────────────────────────────────
    // App users can read/write their own sessions only.
    match /sessions/{sessionId} {
      allow read:   if isAppUser() && resource.data.userId == request.auth.uid;
      allow create: if isAppUser() && request.resource.data.userId == request.auth.uid;
      allow update: if isAppUser() && resource.data.userId == request.auth.uid;
      allow delete: if isAppUser() && resource.data.userId == request.auth.uid;
    }

    // ── Conditions history ────────────────────────────────────────────────────
    // One doc per location per day: {slug}_{date}
    // Written automatically on daily rollover; used for future analytics.
    match /conditionsHistory/{entry} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null;
    }

    // ── Conditions cache ──────────────────────────────────────────────────────
    // Weather/tide data is not sensitive — any authenticated user can read/write.
    // isAppUser() is intentionally NOT used here to avoid auth timing issues
    // where the read fires before the users doc is confirmed to exist.
    match /conditions/{locationSlug} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null;
    }
  }
}
