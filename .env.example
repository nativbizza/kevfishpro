# Copy this to .env.local and fill in your values
# Firebase — get from: Firebase Console > Project Settings > Your apps > Web app
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Stormglass — get from: stormglass.io > Dashboard > API key
VITE_STORMGLASS_API_KEY=

# App Check — get from: google.com/recaptcha/admin (reCAPTCHA v3, domain: kevfishpro.web.app)
VITE_RECAPTCHA_SITE_KEY=
# Set to true for local dev; copy the token printed in the browser console
# to Firebase Console > App Check > your app > Manage debug tokens
VITE_APPCHECK_DEBUG_TOKEN=true
